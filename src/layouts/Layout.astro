---
import '../styles.css'
import { translations, LANGS, type Lang } from '../i18n/translations'
import { SITE, OG_LOCALE, localeUrl } from '../lib/i18nRoutes'

interface Props {
  lang?: Lang
}
const { lang = 'vi' } = Astro.props
const seo = translations[lang].seo
const canonical = localeUrl(lang)
const ogImage = `${SITE}/images/brand/og-image.jpg`

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Công ty TNHH Thương mại & Dịch vụ Kỹ thuật Minh Huy',
  alternateName: 'Minh Huy Maritime',
  url: SITE + '/',
  logo: `${SITE}/images/brand/logo.png`,
  image: ogImage,
  description: seo.description,
  email: 'dichvuminhhuy@gmail.com',
  telephone: '+84909239268',
  taxID: '0317945836',
  priceRange: '$$',
  areaServed: 'VN',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '3/414B Ấp Nhị Tân, Xã Xuân Thới Sơn',
    addressLocality: 'Thành phố Hồ Chí Minh',
    addressCountry: 'VN',
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: '08:00',
    closes: '17:30',
  },
  sameAs: ['https://www.facebook.com/dichvuhanghai.minhhuy/'],
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/images/brand/favicon.png" />
    <link rel="apple-touch-icon" href="/images/brand/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="1tqPO2Nrgh4rzf5B5RdQ3ExQ0P5284xt7aNGhNvWFos" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="theme-color" content="#1e3a6b" />
    <link rel="canonical" href={canonical} />

    <!-- hreflang: mỗi ngôn ngữ một URL + bản mặc định -->
    {LANGS.map(({ code }) => <link rel="alternate" hreflang={code} href={localeUrl(code)} />)}
    <link rel="alternate" hreflang="x-default" href={localeUrl('vi')} />

    <!-- Open Graph (chia sẻ link Facebook/Zalo/Messenger) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Minh Huy Maritime" />
    <meta property="og:locale" content={OG_LOCALE[lang]} />
    {
      LANGS.filter((l) => l.code !== lang).map(({ code }) => (
        <meta property="og:locale:alternate" content={OG_LOCALE[code]} />
      ))
    }
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Minh Huy - Dịch vụ An toàn Hàng hải" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Dữ liệu có cấu trúc cho Google (doanh nghiệp địa phương) -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Analytics 4 (tất cả trang ngôn ngữ) -->
    <Fragment set:html={'<script async src="https://www.googletagmanager.com/gtag/js?id=G-3G318SVJ8N"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag("js",new Date());gtag("config","G-3G318SVJ8N",{anonymize_ip:true});</script>'} />
  </head>
  <body>
    <slot />
  </body>
</html>
